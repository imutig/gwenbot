<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mon Planning de Stream 🌸</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Quicksand', 'sans-serif'],
                    },
                    colors: {
                        pastel: {
                            pink: '#FFE4E1',
                            bg: '#FFF0F5',
                            dark: '#D87093',
                            text: '#5c404c',
                            card: '#FFFFFF',
                            accent: '#FFB6C1'
                        }
                    },
                    boxShadow: {
                        'kawaii': '0 10px 25px -5px rgba(255, 182, 193, 0.4), 0 8px 10px -6px rgba(255, 182, 193, 0.2)',
                    },
                    animation: {
                        'float': 'float 6s ease-in-out infinite',
                        'float-delayed': 'float 6s ease-in-out 3s infinite',
                        'wiggle': 'wiggle 3s ease-in-out infinite',
                    },
                    keyframes: {
                        float: {
                            '0%, 100%': { transform: 'translateY(0) rotate(0deg)' },
                            '50%': { transform: 'translateY(-20px) rotate(10deg)' },
                        },
                        wiggle: {
                            '0%, 100%': { transform: 'rotate(-3deg)' },
                            '50%': { transform: 'rotate(3deg)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #2a1f24; /* Fond sombre pour faire ressortir le cadre du planning */
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            color: #5c404c;
        }
        
        /* Personnalisation de la scrollbar pour le navigateur */
        ::-webkit-scrollbar {
            width: 10px;
            height: 10px;
        }
        ::-webkit-scrollbar-track {
            background: #2a1f24;
        }
        ::-webkit-scrollbar-thumb {
            background: #FFB6C1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #FF9AA2;
        }
    </style>
</head>
<body class="p-8 overflow-auto flex flex-col items-center">

    <!-- Indication pour la capture (invisible sur l'image finale si on cadre bien) -->
    <p class="text-white/60 mb-6 font-sans text-sm tracking-wide bg-black/30 px-4 py-2 rounded-full">
        📸 Outil de capture (ex: Win+Shift+S) : Capturez le bloc clair ci-dessous, il est au format parfait 16:9 !
    </p>

    <!-- Conteneur 16:9 à capturer (1280x720) -->
    <div id="capture-zone" class="relative w-[1280px] h-[720px] bg-pastel-bg rounded-[2.5rem] overflow-hidden shadow-[0_0_50px_rgba(255,182,193,0.3)] border-[6px] border-white shrink-0 flex flex-col" style="background-image: radial-gradient(#FFB6C1 1.5px, transparent 1.5px); background-size: 30px 30px;">

        <!-- Fleurs décoratives en arrière-plan (SVG) -->
        <div class="absolute -top-10 -left-10 w-48 h-48 text-pastel-accent opacity-50 animate-float pointer-events-none z-0">
            <svg viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M50 15 C 60 15, 65 35, 50 50 C 35 35, 40 15, 50 15 Z" />
                <path d="M85 50 C 85 40, 65 35, 50 50 C 65 65, 85 60, 85 50 Z" />
                <path d="M50 85 C 40 85, 35 65, 50 50 C 65 65, 60 85, 50 85 Z" />
                <path d="M15 50 C 15 60, 35 65, 50 50 C 35 35, 15 40, 15 50 Z" />
                <circle cx="50" cy="50" r="10" fill="#FFF8DC" />
            </svg>
        </div>
        
        <div class="absolute top-20 right-[-30px] w-32 h-32 text-pastel-accent opacity-40 animate-float-delayed pointer-events-none z-0">
            <svg viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M50 15 C 60 15, 65 35, 50 50 C 35 35, 40 15, 50 15 Z" />
                <path d="M85 50 C 85 40, 65 35, 50 50 C 65 65, 85 60, 85 50 Z" />
                <path d="M50 85 C 40 85, 35 65, 50 50 C 65 65, 60 85, 50 85 Z" />
                <path d="M15 50 C 15 60, 35 65, 50 50 C 35 35, 15 40, 15 50 Z" />
                <circle cx="50" cy="50" r="10" fill="#FFF8DC" />
            </svg>
        </div>

        <div class="absolute bottom-10 left-[20%] w-24 h-24 text-pastel-accent opacity-60 animate-float-delayed pointer-events-none z-0" style="animation-delay: 1.5s;">
            <svg viewBox="0 0 100 100" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M50 15 C 60 15, 65 35, 50 50 C 35 35, 40 15, 50 15 Z" />
                <path d="M85 50 C 85 40, 65 35, 50 50 C 65 65, 85 60, 85 50 Z" />
                <path d="M50 85 C 40 85, 35 65, 50 50 C 65 65, 60 85, 50 85 Z" />
                <path d="M15 50 C 15 60, 35 65, 50 50 C 35 35, 15 40, 15 50 Z" />
                <circle cx="50" cy="50" r="10" fill="#FFF8DC" />
            </svg>
        </div>

        <!-- Contenu du Planning -->
        <div class="relative z-10 flex flex-col h-full w-full pt-8 px-6">
            
            <!-- En-tête : Avatar + Titre + Réseaux -->
            <div class="flex items-center justify-between mb-6">
                <!-- Avatar et Titre -->
                <div class="flex items-center gap-6">
                    <div class="w-24 h-24 bg-white rounded-full border-4 border-pastel-accent shadow-kawaii overflow-hidden p-1 relative shrink-0">
                        <img src="https://api.dicebear.com/7.x/adventurer/svg?seed=KawaiiStreamer&backgroundColor=ffe4e1" alt="Avatar" class="w-full h-full rounded-full object-cover">
                    </div>
                    <div>
                        <h1 class="text-4xl font-bold text-pastel-dark tracking-wide drop-shadow-sm">
                            Planning de la semaine
                        </h1>
                        <p class="text-lg font-semibold bg-white px-5 py-1.5 rounded-full shadow-sm text-pastel-text border border-pastel-pink mt-2 inline-block">
                            Semaine du 10 au 16 Avril 🎀
                        </p>
                    </div>
                </div>
                
                <!-- Réseaux / Branding -->
                <div class="bg-white/80 backdrop-blur-sm px-6 py-4 rounded-2xl border-2 border-pastel-pink shadow-sm text-right">
                    <p class="text-pastel-dark font-bold text-lg mb-1 flex items-center justify-end gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M21 8.5c-1.2 0-2.3-.4-3.1-1.2A4.2 4.2 0 0 1 16.7 4v8.1a5.7 5.7 0 1 1-5.7-5.7c.3 0 .7 0 1 .1v3a2.8 2.8 0 1 0 1.7 2.6V0h3a4.2 4.2 0 0 0 4.2 4.2V8.5z"/></svg>
                        @xsgwen
                    </p>
                    <p class="text-pastel-dark font-bold text-lg flex items-center justify-end gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
                        twitch.tv/xsgwen
                    </p>
                </div>
            </div>

            <!-- Colonnes des jours (Emploi du temps) -->
            <div class="grid grid-cols-7 gap-2 flex-1 mb-8">
                
                <!-- Lundi -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">☕</span>
                        <h2 class="font-bold text-pastel-dark">Lundi</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-3 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-xs font-bold py-1 px-3 rounded-full mb-2">20h00 - 23h00</div>
                            <h3 class="font-bold text-pastel-dark leading-tight">Just Chatting</h3>
                            <p class="text-[11px] text-pastel-text/80 mt-1.5 leading-tight">On papote de tout et de rien ! 💕</p>
                        </div>
                    </div>
                </div>

                <!-- Mardi -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">🎮</span>
                        <h2 class="font-bold text-pastel-dark">Mardi</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-3 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-xs font-bold py-1 px-3 rounded-full mb-2">19h30 - 22h30</div>
                            <h3 class="font-bold text-pastel-dark leading-tight">Stardew Valley</h3>
                            <p class="text-[11px] text-pastel-text/80 mt-1.5 leading-tight">On agrandit notre jolie ferme 🌻</p>
                        </div>
                    </div>
                </div>

                <!-- Mercredi (Repos) -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white/50 rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-dashed border-b-0 shadow-sm">
                        <span class="block text-2xl mb-1 grayscale opacity-70">💤</span>
                        <h2 class="font-bold text-pastel-text/60">Mercredi</h2>
                    </div>
                    <div class="bg-pastel-pink/20 rounded-b-2xl border-2 border-pastel-pink border-dashed p-2.5 flex flex-col items-center justify-center flex-1">
                        <p class="font-bold text-pastel-dark text-lg mb-1">Repos</p>
                        <p class="text-xs text-pastel-text/70 text-center">Je dors pour reprendre des forces !</p>
                    </div>
                </div>

                <!-- Jeudi -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">🔫</span>
                        <h2 class="font-bold text-pastel-dark">Jeudi</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-3 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-xs font-bold py-1 px-3 rounded-full mb-2">20h00 - 00h00</div>
                            <h3 class="font-bold text-pastel-dark leading-tight">Valorant</h3>
                            <p class="text-[11px] text-pastel-text/80 mt-1.5 leading-tight">Tryhard mignon avec les subs 🌸</p>
                        </div>
                    </div>
                </div>

                <!-- Vendredi -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">👻</span>
                        <h2 class="font-bold text-pastel-dark">Vendredi</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-3 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-xs font-bold py-1 px-3 rounded-full mb-2">21h00 - 01h00</div>
                            <h3 class="font-bold text-pastel-dark leading-tight">Soirée Horreur</h3>
                            <p class="text-[11px] text-pastel-text/80 mt-1.5 leading-tight">Préparez-vous à me voir crier 🫣</p>
                        </div>
                    </div>
                </div>

                <!-- Samedi -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">🎨</span>
                        <h2 class="font-bold text-pastel-dark">Samedi</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-3 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-xs font-bold py-1 px-3 rounded-full mb-2">15h00 - 18h00</div>
                            <h3 class="font-bold text-pastel-dark leading-tight">Art Stream</h3>
                            <p class="text-[11px] text-pastel-text/80 mt-1.5 leading-tight">Dessin d'emotes et papote 🖍️</p>
                        </div>
                    </div>
                </div>

                <!-- Dimanche -->
                <div class="flex flex-col h-full transform transition duration-300 hover:-translate-y-1">
                    <div class="bg-white rounded-t-2xl py-3 text-center border-2 border-pastel-pink border-b-0 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-pastel-accent to-pink-300"></div>
                        <span class="block text-2xl mb-1">🍿</span>
                        <h2 class="font-bold text-pastel-dark">Dimanche</h2>
                    </div>
                    <div class="bg-white/60 backdrop-blur-sm rounded-b-2xl border-2 border-pastel-pink p-2.5 flex flex-col gap-3 flex-1 shadow-inner">
                        <div class="bg-white rounded-xl p-2.5 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center">
                            <div class="bg-pastel-pink text-pastel-dark text-[10px] font-bold py-1 px-2 rounded-full mb-1.5">18h00 - 20h00</div>
                            <h3 class="font-bold text-pastel-dark text-sm leading-tight">React & Vidéos</h3>
                        </div>
                        <div class="bg-white rounded-xl p-2.5 shadow-sm border border-pastel-pink/50 flex flex-col items-center text-center mt-2">
                            <div class="bg-pastel-pink text-pastel-dark text-[10px] font-bold py-1 px-2 rounded-full mb-1.5">20h00 - 23h00</div>
                            <h3 class="font-bold text-pastel-dark text-sm leading-tight">Jeu surprise ✨</h3>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>